{
    "name": "react-dynform",
    "version": "0.1.0",
    "description": "A schema-driven dynamic form engine for React. Render fully functional forms from a JSON schema — with conditional logic, multi-step wizards, validation, and a plugin system.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "bunchee",
        "dev": "bunchee --watch",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run typecheck && npm run build && npm run test:run"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "bunchee": "latest",
        "typescript": "^5.0.0",
        "@types/node": "^20.0.0",
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "vitest": "^2.0.0",
        "@testing-library/react": "^14.0.0",
        "@testing-library/user-event": "^14.0.0",
        "@vitejs/plugin-react": "^4.0.0",
        "jsdom": "^24.0.0",
        "@vitest/coverage-v8": "^2.0.0"
    },
    "keywords": [
        "react",
        "form",
        "schema",
        "dynamic-form",
        "json-schema",
        "form-builder",
        "conditional-logic",
        "multi-step",
        "validation",
        "headless"
    ],
    "author": "",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": ""
    },
    "engines": {
        "node": ">=20"
    }
}